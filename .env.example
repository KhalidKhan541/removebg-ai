# Cloudflare Pages Environment Variables
# Copy this file to .env.local for local development (not committed)
# For production, set these in the Cloudflare Dashboard

# Cloudflare Account
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# KV Namespace IDs (from `wrangler kv namespace create` output)
ANALYTICS_KV_ID=
RATE_LIMIT_KV_ID=

# Optional: Custom settings
# NODE_VERSION=18
